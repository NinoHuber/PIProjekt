{
  "openapi": "3.0.4",
  "info": {
    "title": "PIProjektAPI",
    "version": "1.0"
  },
  "paths": {
    "/api/WeddingPlanner/vendors": {
      "get": {
        "tags": [
          "WeddingPlanner"
        ],
        "parameters": [
          {
            "name": "categoryName",
            "in": "query",
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "searchTerm",
            "in": "query",
            "schema": {
              "type": "string",
              "default": ""
            }
          },
          {
            "name": "page",
            "in": "query",
            "schema": {
              "type": "integer",
              "format": "int32",
              "default": 1
            }
          },
          {
            "name": "pageSize",
            "in": "query",
            "schema": {
              "type": "integer",
              "format": "int32",
              "default": 3
            }
          }
        ],
        "responses": {
          "200": {
            "description": "OK",
            "content": {
              "text/plain": {
                "schema": {
                  "$ref": "#/components/schemas/PartnerResponseDtoPagedResultDto"
                }
              },
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/PartnerResponseDtoPagedResultDto"
                }
              },
              "text/json": {
                "schema": {
                  "$ref": "#/components/schemas/PartnerResponseDtoPagedResultDto"
                }
              }
            }
          }
        }
      }
    },
    "/api/WeddingPlanner/weddings": {
      "post": {
        "tags": [
          "WeddingPlanner"
        ],
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/WeddingSubmissionDto"
              }
            },
            "text/json": {
              "schema": {
                "$ref": "#/components/schemas/WeddingSubmissionDto"
              }
            },
            "application/*+json": {
              "schema": {
                "$ref": "#/components/schemas/WeddingSubmissionDto"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "OK"
          }
        }
      }
    }
  },
  "components": {
    "schemas": {
      "PartnerResponseDto": {
        "type": "object",
        "properties": {
          "id": {
            "type": "integer",
            "format": "int32"
          },
          "name": {
            "type": "string",
            "nullable": true
          },
          "phone": {
            "type": "string",
            "nullable": true
          },
          "email": {
            "type": "string",
            "nullable": true
          },
          "address": {
            "type": "string",
            "nullable": true
          },
          "price": {
            "type": "number",
            "format": "double"
          },
          "commissionPercentage": {
            "type": "number",
            "format": "double"
          },
          "hasHall": {
            "type": "boolean",
            "nullable": true
          },
          "startTime": {
            "type": "string",
            "nullable": true
          },
          "endTime": {
            "type": "string",
            "nullable": true
          }
        },
        "additionalProperties": false
      },
      "PartnerResponseDtoPagedResultDto": {
        "type": "object",
        "properties": {
          "items": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/PartnerResponseDto"
            },
            "nullable": true
          },
          "totalCount": {
            "type": "integer",
            "format": "int32"
          },
          "totalPages": {
            "type": "integer",
            "format": "int32"
          },
          "currentPage": {
            "type": "integer",
            "format": "int32"
          }
        },
        "additionalProperties": false
      },
      "WeddingSubmissionDto": {
        "type": "object",
        "properties": {
          "weddingDate": {
            "type": "string",
            "format": "date-time"
          },
          "restaurantId": {
            "type": "integer",
            "format": "int32",
            "nullable": true
          },
          "pastryId": {
            "type": "integer",
            "format": "int32",
            "nullable": true
          },
          "floristId": {
            "type": "integer",
            "format": "int32",
            "nullable": true
          },
          "weddingHallId": {
            "type": "integer",
            "format": "int32",
            "nullable": true
          },
          "bandIds": {
            "type": "array",
            "items": {
              "type": "integer",
              "format": "int32"
            },
            "nullable": true
          }
        },
        "additionalProperties": false
      }
    }
  },
  "tags": [
    {
      "name": "WeddingPlanner"
    }
  ]
}